starter:
  flour
  water
  hydration = 100%

dough:
  starter = 20.0%
  water = 60.5%
  flour
  salt = 2%
  hydration = 70%
  total_flour = 1000g / 2

⚠ starter.total_water = 1 * starter.total_flour --> (0.5% -0.50)
⚠ dough.starter = 0.2 * dough.total_flour --> (0.3% -0.50)
⚠ dough.water = 0.605 * dough.total_flour --> (0.2% -1.00)
⚠ dough.total_water = 0.7 * dough.total_flour --> (0.1% 1.00)
⚠ Inconsistent equations
