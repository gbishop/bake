starter ^ 5%:
  flour
  water
  hydration = 100%

dough:
  flour
  water
  salt = 2%
  starter.total_flour = 5%
  starter = 2 * flour / 10
  hydration = 70%
  total_flour = 1000g

/*+
┌─────────┬─────────┬───────────┬───────┬─────────┬────────┐
│   part  │  grams  │    name   │   %   │  flour  │ water  │
├─────────┼─────────┼───────────┼───────┼─────────┼────────┤
│ starter │  105    │ + 5.0g    │  10.0 │   50.0  │  50.0  │
│         │   52.5  │ flour     │   5.0 │   50.0  │        │
│         │   52.5  │ water     │   5.0 │         │  50.0  │
├─────────┼─────────┼───────────┼───────┼─────────┼────────┤
│ dough   │ 1720    │           │ 172.0 │ 1000    │ 700    │
│         │  950    │ flour     │  95.0 │  950    │        │
│         │  650    │ water     │  65.0 │         │ 650    │
│         │   20.0  │ salt      │   2.0 │         │        │
│         │  100    │ starter   │  10.0 │   50.0  │  50.0  │
│         │         │ hydration │  70.0 │         │        │
├─────────┼─────────┼───────────┼───────┼─────────┼────────┤
│         │  110    │ protein   │   7.0 │         │        │
│         │   30.0  │ fiber     │   1.9 │         │        │
│         │   12.0  │ fat       │   0.8 │         │        │
│         │  740    │ carbs     │  47.3 │         │        │
└─────────┴─────────┴───────────┴───────┴─────────┴────────┘+*/

