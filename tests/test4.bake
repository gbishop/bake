rye_starter:
  rye
  water
  hydration = 100%

dough:
  rye_starter = 20.0%
  warm_water = 60.5%
  flour
  salt = 2%
  hydration = 70%
  total_flour = 1000g / 2

⚠ rye_starter.total_water = 1 * rye_starter.total_flour --> (0.5% -0.50)
⚠ dough.rye_starter = 0.2 * dough.total_flour --> (0.3% -0.50)
⚠ dough.warm_water = 0.605 * dough.total_flour --> (0.2% -1.00)
⚠ dough.total_water = 0.7 * dough.total_flour --> (0.1% 1.00)
⚠ Inconsistent equations
